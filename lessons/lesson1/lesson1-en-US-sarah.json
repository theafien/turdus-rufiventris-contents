{"audioUrl": "", "duration": 103.527, "paragraphs": [{"id": "p1", "sentences": [{"id": "p1s1", "text": "Hello! My name is Lucas.", "boundaries": [{"text": "Hello! ", "start": 0.0, "end": 0.639}, {"text": "My ", "start": 0.848, "end": 0.952}, {"text": "name ", "start": 1.01, "end": 1.149}, {"text": "is ", "start": 1.184, "end": 1.242}, {"text": "Lucas.", "start": 1.312, "end": 1.927}]}, {"id": "p1s2", "text": "I am twenty-five years old.", "boundaries": [{"text": "I ", "start": 2.519, "end": 2.554}, {"text": "am ", "start": 2.612, "end": 2.682}, {"text": "twenty-five ", "start": 2.717, "end": 3.146}, {"text": "years ", "start": 3.17, "end": 3.344}, {"text": "old.", "start": 3.39, "end": 3.762}]}, {"id": "p1s3", "text": "I am Brazilian and I live in the city of São Paulo.", "boundaries": [{"text": "I ", "start": 4.354, "end": 4.4}, {"text": "am ", "start": 4.516, "end": 4.598}, {"text": "Brazilian ", "start": 4.632, "end": 5.097}, {"text": "and ", "start": 5.143, "end": 5.213}, {"text": "I ", "start": 5.271, "end": 5.294}, {"text": "live ", "start": 5.352, "end": 5.492}, {"text": "in ", "start": 5.526, "end": 5.573}, {"text": "the ", "start": 5.608, "end": 5.677}, {"text": "city ", "start": 5.712, "end": 5.921}, {"text": "of ", "start": 5.968, "end": 6.014}, {"text": "São ", "start": 6.072, "end": 6.223}, {"text": "Paulo.", "start": 6.269, "end": 6.803}]}, {"id": "p1s4", "text": "My house is small, but it is very beautiful and comfortable.", "boundaries": [{"text": "My ", "start": 7.396, "end": 7.512}, {"text": "house ", "start": 7.558, "end": 7.755}, {"text": "is ", "start": 7.802, "end": 7.872}, {"text": "small, ", "start": 7.918, "end": 8.301}, {"text": "but ", "start": 8.336, "end": 8.51}, {"text": "it ", "start": 8.568, "end": 8.696}, {"text": "is ", "start": 8.742, "end": 8.812}, {"text": "very ", "start": 8.882, "end": 9.067}, {"text": "beautiful ", "start": 9.114, "end": 9.462}, {"text": "and ", "start": 9.52, "end": 9.59}, {"text": "comfortable.", "start": 9.