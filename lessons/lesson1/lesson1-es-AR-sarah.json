text": "Es una vida simple, pero soy muy feliz.", "boundaries": [{"text": "Es ", "start": 124.294, "end": 124.503}, {"text": "una ", "start": 124.561, "end": 124.689}, {"text": "vida ", "start": 124.735, "end": 124.944}, {"text": "simple, ", "start": 125.014, "end": 125.432}, {"text": "pero ", "start": 125.455, "end": 125.664}, {"text": "soy ", "start": 125.71, "end": 125.931}, {"text": "muy", "start": 126.012, "end": 126.244}]}]}]}